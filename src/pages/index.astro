---
import BlogCard from "@/components/BlogCard.astro"
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts } from "@/lib/content"
import { withBase } from "@/lib/utils"

const posts = await getPosts()
const latestPosts = posts.slice(0, 3)
---

<Layout contentTop="tight">
  <MetaPage slot="head" />
  <hero-copy>
    <p>Personal blog</p>
    <h1>t4k1 blog</h1>
  </hero-copy>
  {latestPosts.length > 0 && (
    <section>
      <section-header>
        <h2>Latest posts</h2>
        <a href={withBase("/posts")}>View all</a>
      </section-header>
      <ul>
        {latestPosts.map((post) => <BlogCard post={post} />)}
      </ul>
    </section>
  )}
</Layout>

<style>
  hero-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    margin-block-end: var(--space-xl);

    > p:first-of-type {
      font-size: var(--step--1);
      font-weight: var(--font-weight-medium);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted-foreground);
    }

    h1 {
      font-size: clamp(2.5rem, 2.0718rem + 2.0866vw, 3.6563rem);
      line-height: 0.96;
      font-weight: var(--font-weight-medium);
      max-inline-size: 12ch;
    }

    > p:last-of-type {
      max-inline-size: 36rem;
      font-size: var(--step-0);
      color: var(--muted-foreground);
    }
  }

  section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-s);
    margin-block-end: var(--space-s);

    h2 {
      font-size: var(--step-1);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
    }

    a {
      color: var(--muted-foreground);
      font-size: var(--step--1);
    }
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  @media (width < 40rem) {
    section-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
